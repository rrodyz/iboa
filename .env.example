# ═══════════════════════════════════════════════════════════════════════════════
# A3 ERP — Fichier d'exemple (.env.example)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copier : cp .env.example .env
# 2. Générer la clé : php artisan key:generate
# 3. Configurer DB, mail et Redis selon votre environnement
# Pour le déploiement VPS → voir .env.production.example
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="A3 ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_TIMEZONE=Africa/Ouagadougou

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# ── Base de données ───────────────────────────────────────────────────────────
# Développement local (Laragon) : MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iboa_erp
DB_USERNAME=root
DB_PASSWORD=

# Tests (PHPUnit/Pest) : SQLite in-memory (défini dans phpunit.xml)
# DB_CONNECTION=sqlite

# ── Session ───────────────────────────────────────────────────────────────────
# Développement : file (simple)
# Production    : redis (voir .env.production.example)
SESSION_DRIVER=file
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true  ← activer en production HTTPS uniquement

# ── Cache ─────────────────────────────────────────────────────────────────────
# Développement : file
# Production    : redis (×50 plus rapide)
CACHE_STORE=file
CACHE_PREFIX=a3erp_

# ── File d'attente ────────────────────────────────────────────────────────────
# Développement : database
# Production    : redis (voir .env.production.example)
QUEUE_CONNECTION=database

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Mail ──────────────────────────────────────────────────────────────────────
# Développement : log (les emails s'affichent dans storage/logs/laravel.log)
# Production    : smtp avec identifiants réels
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@a3erp.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── API CORS ──────────────────────────────────────────────────────────────────
# Origines autorisées pour l'API REST (séparées par virgule)
CORS_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost,http://localhost:5173

# ── Intégration Orange Money BF (optionnel) ───────────────────────────────────
# Obtenir sur le portail développeur Orange Money Burkina Faso
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/bf/v1
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_CALLBACK_URL=${APP_URL}/integrations/webhooks/orange-money

# ── Intégration Twilio SMS (optionnel) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Divers ────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
VITE_APP_NAME="${APP_NAME}"
