APP_NAME="IBOA Tests"
APP_ENV=testing
APP_KEY=base64:UkazjoJ8wcw4V2f0h9oSECNldzPqi9T2E+Qbz3/F2l0=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Base de données : SQLite en mémoire — rapide, isolée par test
DB_CONNECTION=sqlite
DB_DATABASE=:memory:
DB_FOREIGN_KEYS=true

# Désactive les drivers persistants pendant les tests
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array
BROADCAST_CONNECTION=null
MAIL_MAILER=array
FILESYSTEM_DISK=local

# Désactive les outils de monitoring qui pourraient déclencher des prompts
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

# Vide les valeurs réseau qui pourraient ralentir/bloquer les tests
REDIS_HOST=127.0.0.1
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="tests@example.com"
MAIL_FROM_NAME="${APP_NAME}"
