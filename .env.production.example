# ═══════════════════════════════════════════════════════════════════════════════
# A3 ERP — Configuration de production (VPS / CyberPanel)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copier ce fichier :  cp .env.production.example .env
# 2. Remplir TOUTES les valeurs entre < >
# 3. Générer une clé :    php artisan key:generate
# 4. NE JAMAIS versionner .env avec de vraies valeurs
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="A3 ERP"
APP_ENV=production
APP_KEY=                              # php artisan key:generate --force
APP_DEBUG=false
APP_URL=https://<votre-domaine.com>

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_TIMEZONE=Africa/Ouagadougou
BCRYPT_ROUNDS=12

# ── Base de données MySQL ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<nom_base>
DB_USERNAME=<utilisateur_mysql>
DB_PASSWORD=<mot_de_passe_mysql>

# ── Redis (OBLIGATOIRE en production pour perf ×10-50) ───────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=a3erp_

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.<votre-domaine.com>
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── File d'attente ────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
# Worker démarré via Supervisor (voir deploy/supervisor.conf)

# ── Mail SMTP ─────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<smtp.votre-fournisseur.com>
MAIL_PORT=587
MAIL_USERNAME=<adresse@votre-domaine.com>
MAIL_PASSWORD=<mot_de_passe_smtp>
MAIL_FROM_ADDRESS="noreply@<votre-domaine.com>"
MAIL_FROM_NAME="A3 ERP"

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# ── Intégration Orange Money BF ───────────────────────────────────────────────
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/bf/v1
ORANGE_MONEY_MERCHANT_KEY=<merchant_key>
ORANGE_MONEY_CLIENT_ID=<client_id>
ORANGE_MONEY_CLIENT_SECRET=<client_secret>
ORANGE_MONEY_CALLBACK_URL=${APP_URL}/integrations/webhooks/orange-money

# ── Intégration Twilio SMS ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<AC...>
TWILIO_AUTH_TOKEN=<auth_token>
TWILIO_FROM_NUMBER=+226XXXXXXXX

# ── Divers ────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
APP_MAINTENANCE_DRIVER=file
