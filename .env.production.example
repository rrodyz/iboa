APP_NAME="IBOA ERP"
APP_ENV=production
APP_KEY=                      # php artisan key:generate
APP_DEBUG=false
APP_URL=https://votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logs ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

# ── Base de données ─────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iboa_erp
DB_USERNAME=iboa_user         # Utiliser un utilisateur dédié (pas root)
DB_PASSWORD=                  # Mot de passe fort

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480           # 8 heures
SESSION_ENCRYPT=true           # Chiffrer les sessions en production
SESSION_PATH=/
SESSION_DOMAIN=.votre-domaine.com
SESSION_SECURE_COOKIE=true     # HTTPS uniquement
SESSION_SAME_SITE=lax

# ── Cache & Queue ────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database      # Passer à Redis pour plus de charge
CACHE_STORE=database           # Passer à Redis pour plus de perf

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-provider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@votre-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
